{
  "name": "@paybook/db",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./payment-application": {
      "types": "./src/payment-application.ts",
      "default": "./src/payment-application.ts"
    }
  },
  "scripts": {
    "db:generate": "node ../../node_modules/prisma/build/index.js generate",
    "db:migrate": "node ../../node_modules/prisma/build/index.js migrate dev",
    "db:push": "node ../../node_modules/prisma/build/index.js db push",
    "db:studio": "node ../../node_modules/prisma/build/index.js studio",
    "db:seed": "node ../../node_modules/ts-node/dist/bin.js prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1"
  },
  "devDependencies": {
    "prisma": "^6.10.1",
    "typescript": "^5.8.3",
    "ts-node": "^10.9.2"
  }
}
