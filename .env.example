# ─── Nomba ─────────────────────────────────────────────────────────────────────
NOMBA_BASE_URL=https://api.nomba.com/v1   # LIVE (switched 2026-07-07); sandbox was https://sandbox.nomba.com/v1
NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
# "shared" (default; sandbox) = one VA per Collection + claim-and-bind matching.
# "per_payer" (production) = a dedicated VA per enrollment, exact attribution.
NOMBA_VA_STRATEGY=shared
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_WEBHOOK_SECRET=

# ─── Database (Supabase) ────────────────────────────────────────────────────────
# Connection pooler URL (used by Prisma in serverless/edge contexts)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Session pooler (used by Prisma migrate — supports DDL)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Redis (Upstash — token cache + BullMQ) ────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Used by BullMQ (ioredis format)
REDIS_URL=

# ─── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Web Push ──────────────────────────────────────────────────────────────────
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=

# ─── Auth.js v5 ─────────────────────────────────────────────────────────────────
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3002

# ─── Supabase Realtime ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Webhook service ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# AES-256-GCM key (64 hex chars) for encrypting owner Nomba credentials at rest
PAYBOOK_ENCRYPTION_KEY=
